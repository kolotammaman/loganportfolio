---
---

<section class="relative min-h-screen flex items-start overflow-hidden" aria-label="Introduction">

  <!-- Dot grid texture -->
  <div
    class="absolute inset-0 opacity-[0.045]"
    style="background-image: radial-gradient(circle, #111110 1px, transparent 1px); background-size: 28px 28px;"
    aria-hidden="true"
  ></div>

  <!-- Large decorative circles — hidden on mobile, float on desktop -->
  <div
    class="hero-float-outer hidden md:block absolute -top-64 -right-64 w-[640px] h-[640px] rounded-full border border-border/60 pointer-events-none"
    aria-hidden="true"
  ></div>
  <div
    class="hero-float-inner hidden md:block absolute -top-48 -right-48 w-[480px] h-[480px] rounded-full border border-border/40 pointer-events-none"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-6xl mx-auto px-6 pt-24 md:pt-28 pb-16 w-full">

    <div class="flex flex-col-reverse md:flex-row md:items-start md:justify-between gap-10 md:gap-16">

      <!-- Left: text content -->
      <div class="flex-1 min-w-0">

        <!-- Status pill -->
        <div class="reveal inline-flex items-center gap-2.5 px-4 py-1.5 border border-border bg-bg-card mb-12 rounded-sm">
          <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse" aria-hidden="true"></span>
          <span class="text-text-muted font-medium text-xs tracking-[0.15em] uppercase" style="font-family: var(--font-body);">Open to Opportunities</span>
        </div>

        <!-- Name — editorial display serif -->
        <h1 class="reveal reveal-delay-1 font-heading font-bold leading-[0.95] tracking-tight text-primary mb-8"
            style="font-size: clamp(3rem, 8vw, 7.5rem);">
          Logan<br>Moseley.
        </h1>

        <!-- Role — all-caps Inter -->
        <p class="reveal reveal-delay-2 text-text-muted text-sm font-medium tracking-[0.2em] uppercase mb-5"
           style="font-family: var(--font-body);">
          Project &amp; Program Operations
        </p>

        <!-- Summary -->
        <p class="reveal reveal-delay-2 text-text-secondary text-lg leading-relaxed max-w-lg mb-10">
          I keep complex operations running without the chaos. Based at
          <span class="font-semibold text-text">Penn Dental Medicine</span>
          — where precision matters and nothing can wait.
        </p>

        <!-- CTA buttons — architectural (no border-radius) -->
        <div class="reveal reveal-delay-3 flex flex-wrap gap-3 mb-20">
          <a
            href="#contact"
            class="group inline-flex items-center gap-2 px-7 py-3.5 bg-primary text-white text-sm font-semibold tracking-wide hover:bg-accent active:scale-95 transition-all duration-300 cursor-pointer"
          >
            Get in Touch
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href="/LoganMoseley_Resume.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-7 py-3.5 border border-border text-text-secondary text-sm font-semibold tracking-wide hover:border-primary hover:text-primary active:scale-95 transition-all duration-300 cursor-pointer"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Resume
          </a>
        </div>

        <!-- Stats — separated by top rule -->
        <div class="reveal reveal-delay-4 border-t border-border pt-8 grid grid-cols-3 gap-4 sm:gap-8 max-w-xs">
          <div>
            <p class="font-heading font-bold text-4xl text-primary leading-none"
               data-counter="4" data-suffix="+">4+</p>
            <p class="text-text-muted text-xs mt-2 font-medium uppercase tracking-[0.12em]" style="font-family: var(--font-body);">Years Exp.</p>
          </div>
          <div>
            <p class="font-heading font-bold text-4xl text-primary leading-none"
               data-counter="4.0" data-decimal="true">4.0</p>
            <p class="text-text-muted text-xs mt-2 font-medium uppercase tracking-[0.12em]" style="font-family: var(--font-body);">GPA at Penn</p>
          </div>
          <div>
            <p class="font-heading font-bold text-4xl text-primary leading-none">0</p>
            <p class="text-text-muted text-xs mt-2 font-medium uppercase tracking-[0.12em]" style="font-family: var(--font-body);">Breaches</p>
          </div>
        </div>

        <script>
          // Stat counter — animates when the stats row scrolls into view
          function animateCounter(el: HTMLElement) {
            const target = parseFloat(el.dataset.counter!);
            const suffix = el.dataset.suffix ?? '';
            const isDecimal = el.dataset.decimal === 'true';
            const duration = 1200;
            const start = performance.now();

            function tick(now: number) {
              const progress = Math.min((now - start) / duration, 1);
              // ease-out-quart: faster initial rush, dramatic deceleration into final value
              const eased = 1 - Math.pow(1 - progress, 4);
              const current = target * eased;
              el.textContent = isDecimal
                ? current.toFixed(1) + suffix
                : Math.round(current) + suffix;
              if (progress < 1) requestAnimationFrame(tick);
            }
            requestAnimationFrame(tick);
          }

          const counterEls = document.querySelectorAll<HTMLElement>('[data-counter]');
          if (counterEls.length) {
            const counterObserver = new IntersectionObserver(
              (entries) => {
                entries.forEach((entry) => {
                  if (entry.isIntersecting) {
                    animateCounter(entry.target as HTMLElement);
                    counterObserver.unobserve(entry.target);
                  }
                });
              },
              { threshold: 0.5 }
            );
            counterEls.forEach((el) => counterObserver.observe(el));
          }
        </script>

      </div>

      <!-- Right: profile photo -->
      <div class="reveal reveal-delay-2 flex-shrink-0 flex justify-center md:justify-end">
        <div class="relative w-44 sm:w-56 md:w-[268px] lg:w-[296px] h-[240px] sm:h-[320px] md:h-[390px] lg:h-[432px]">
          <!-- Offset decorative border -->
          <div
            class="absolute inset-0 translate-x-3 translate-y-3 rounded-2xl border border-accent/30 pointer-events-none"
            aria-hidden="true"
          ></div>
          <img
            src="/profile.jpg"
            alt="Logan Moseley"
            class="relative w-full h-full object-cover object-top rounded-2xl border border-border/60"
            style="box-shadow: 0 8px 40px rgba(0,0,0,0.45); filter: contrast(1.05) saturate(0.9);"
          />
        </div>
      </div>

    </div>
  </div>

  <!-- Scroll indicator — vertical line with bounce animation -->
  <div class="scroll-indicator absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 text-text-muted" aria-hidden="true">
    <span class="text-xs font-medium tracking-[0.15em] uppercase" style="font-family: var(--font-body);">Scroll</span>
    <div class="w-px h-10 bg-gradient-to-b from-text-muted/50 to-transparent"></div>
  </div>

</section>
