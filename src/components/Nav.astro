---
const navLinks = [
  { href: '#about', label: 'About' },
  { href: '#experience', label: 'Experience' },
  { href: '#skills', label: 'Skills' },
  { href: '#education', label: 'Education' },
  { href: '#contact', label: 'Contact' },
];
---

<nav
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-40 transition-all duration-300"
  aria-label="Main navigation"
>
  <div class="max-w-6xl mx-auto px-6 flex items-center justify-between h-16">

    <!-- Logotype -->
    <a
      href="#"
      class="font-heading font-bold text-xl tracking-tight cursor-pointer text-primary hover:text-accent transition-colors duration-200"
      aria-label="Logan Moseley — Back to top"
    >
      LM
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-1" role="list">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="relative px-4 py-2 text-sm font-medium text-text-secondary hover:text-primary cursor-pointer group" style="transition: color 220ms cubic-bezier(0.22,1,0.36,1);"
            style="font-family: var(--font-body);"
          >
            {label}
            <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-px bg-primary transition-all duration-200 group-hover:w-5" aria-hidden="true" />
          </a>
        </li>
      ))}
      <li>
        <a
          href="/LoganMoseley_Resume.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="ml-4 px-5 py-2 text-sm font-semibold border border-primary text-primary hover:bg-primary hover:text-white transition-all duration-200 cursor-pointer"
          style="font-family: var(--font-body);"
        >
          Resume
        </a>
      </li>
    </ul>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-3 hover:bg-border/30 transition-colors duration-200 cursor-pointer"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open menu"
    >
      <svg class="w-6 h-6 text-text" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu — slides open via max-height transition -->
  <div
    id="mobile-menu"
    class="md:hidden bg-bg border-t border-border overflow-hidden"
    style="max-height: 0; transition: max-height 320ms cubic-bezier(0.22, 1, 0.36, 1);"
    role="menu"
    aria-hidden="true"
  >
    <ul class="px-4 py-3 space-y-1" role="list">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="block px-4 py-3 text-base font-medium text-text-secondary hover:text-primary hover:bg-border/20 transition-colors duration-200 cursor-pointer"
            role="menuitem"
            style="font-family: var(--font-body);"
          >
            {label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="/LoganMoseley_Resume.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="block px-4 py-3 text-base font-semibold text-accent cursor-pointer"
          role="menuitem"
          style="font-family: var(--font-body);"
        >
          Resume
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');

  function openMenu() {
    if (!menu) return;
    menu.style.maxHeight = menu.scrollHeight + 'px';
    menu.setAttribute('aria-hidden', 'false');
    btn?.setAttribute('aria-expanded', 'true');
    btn?.setAttribute('aria-label', 'Close menu');
    if (menuIcon) menuIcon.setAttribute('d', 'M6 18L18 6M6 6l12 12');
  }

  function closeMenu() {
    if (!menu) return;
    menu.style.maxHeight = '0px';
    menu.setAttribute('aria-hidden', 'true');
    btn?.setAttribute('aria-expanded', 'false');
    btn?.setAttribute('aria-label', 'Open menu');
    if (menuIcon) menuIcon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
  }

  btn?.addEventListener('click', () => {
    const isClosed = menu?.getAttribute('aria-hidden') === 'true';
    isClosed ? openMenu() : closeMenu();
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => closeMenu());
  });

  // Scroll: add editorial border-bottom to nav + scroll-spy active section
  const nav = document.getElementById('site-nav');
  const sections = Array.from(document.querySelectorAll<HTMLElement>('section[id]'));
  const navAnchors = Array.from(document.querySelectorAll<HTMLAnchorElement>('#site-nav a[href^="#"]:not([href="#"])'));

  function updateScroll() {
    const scrollY = window.scrollY;

    // Nav border on scroll
    if (scrollY > 40) {
      nav?.classList.add('nav-scrolled');
    } else {
      nav?.classList.remove('nav-scrolled');
    }

    // Scroll-spy: find the last section whose top edge is above the viewport midpoint
    const mid = scrollY + window.innerHeight * 0.35;
    let activeId = '';
    for (const section of sections) {
      if (section.offsetTop <= mid) activeId = section.id;
    }
    navAnchors.forEach((anchor) => {
      anchor.classList.toggle('nav-link-active', anchor.getAttribute('href') === `#${activeId}`);
    });
  }

  window.addEventListener('scroll', updateScroll, { passive: true });
  updateScroll();
</script>
