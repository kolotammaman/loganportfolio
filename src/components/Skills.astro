---
const skillCategories = [
  {
    title: 'Operations & Management',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />',
    skills: ['Project/Program Management', 'Training Logistics', 'Vendor Coordination', 'Version Control', 'Process Optimization', 'Event Production', 'Cross-specialty Training'],
  },
  {
    title: 'Communication',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z" />',
    skills: ['Client/Trainer Liaison', 'Cross-team Coordination', 'De-escalation', 'Onboarding & Training', 'Status Reporting'],
  },
  {
    title: 'Software & Tools',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />',
    skills: ['Advanced PowerPoint', 'Excel Tracking', 'Google Workspace', 'Slack / Asana / Airtable', 'Adobe Illustrator & Photoshop', 'Axium'],
  },
  {
    title: 'Quick Learner',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />',
    skills: ['Workday', 'Concur', 'Ben Buys / Purchase Orders', 'OnFleet', 'Inventory Systems'],
  },
];
---

<section id="skills" class="py-24 md:py-32 border-t border-border" aria-labelledby="skills-heading">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Section label -->
    <div class="reveal mb-14">
      <p class="text-text-muted text-xs font-medium tracking-[0.2em] uppercase mb-4" style="font-family: var(--font-body);">
        04 / Skills
      </p>
      <h2 id="skills-heading" class="font-heading font-bold text-3xl sm:text-4xl lg:text-5xl text-primary leading-tight">
        My toolkit.
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-px bg-border">
      {skillCategories.map((category, i) => (
        <div class={`reveal reveal-delay-${i + 1} bg-bg-card p-7 group hover:bg-accent-soft cursor-default`} style="transition: background-color 320ms cubic-bezier(0.22, 1, 0.36, 1);">
          <!-- Icon -->
          <div class="skill-icon w-10 h-10 flex items-center justify-center border border-border group-hover:border-accent/30 mb-5">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <Fragment set:html={category.icon} />
            </svg>
          </div>

          <!-- Title -->
          <h3 class="font-heading font-semibold text-base text-primary mb-5">{category.title}</h3>

          <!-- Skills list -->
          <ul class="space-y-2.5" role="list">
            {category.skills.map((skill) => (
              <li class="flex items-center gap-2.5 text-text-secondary text-sm" style="font-family: var(--font-body);">
                <span class="w-1 h-1 rounded-full bg-accent/50 shrink-0" aria-hidden="true" />
                {skill}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

  </div>
</section>
