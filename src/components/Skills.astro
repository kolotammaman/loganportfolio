---
const skillCategories = [
  {
    title: 'Operations & Management',
    hex: '#2563EB',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />',
    skills: ['Project/Program Management', 'Training Logistics', 'Vendor Coordination', 'Version Control', 'Process Optimization'],
  },
  {
    title: 'Communication',
    hex: '#8B5CF6',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z" />',
    skills: ['Client/Trainer Liaison', 'Cross-team Coordination', 'De-escalation', 'Onboarding & Training', 'Status Reporting'],
  },
  {
    title: 'Software & Tools',
    hex: '#10B981',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />',
    skills: ['Advanced PowerPoint', 'Excel Tracking', 'Google Workspace', 'Slack / Asana / Airtable', 'Adobe Illustrator & Photoshop'],
  },
  {
    title: 'Quick Learner',
    hex: '#F59E0B',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />',
    skills: ['Workday', 'Concur', 'Ben Buys / Purchase Orders', 'OnFleet', 'Inventory Systems'],
  },
];
---

<section id="skills" class="py-24 md:py-32" aria-labelledby="skills-heading">
  <div class="max-w-6xl mx-auto px-6">
    <div class="reveal text-center mb-14">
      <p class="text-accent font-semibold text-sm tracking-widest uppercase mb-3 font-heading">Skills</p>
      <h2 id="skills-heading" class="font-heading font-black text-3xl sm:text-4xl lg:text-5xl text-text tracking-tight">
        My toolkit.
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {skillCategories.map((category, i) => (
        <div class={`reveal reveal-delay-${i + 1} group glass rounded-2xl p-6 card-hover cursor-default`}>
          <div
            class="w-12 h-12 rounded-2xl flex items-center justify-center mb-5 transition-colors duration-200"
            style={`background: ${category.hex}15;`}
          >
            <svg class="w-6 h-6" style={`color: ${category.hex};`} fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <Fragment set:html={category.icon} />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-base text-text mb-4">
            {category.title}
          </h3>
          <ul class="space-y-2.5" role="list">
            {category.skills.map((skill) => (
              <li class="flex items-center gap-2.5 text-text-secondary text-sm">
                <span class="w-1.5 h-1.5 rounded-full shrink-0" style={`background: ${category.hex}66;`} aria-hidden="true" />
                {skill}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
