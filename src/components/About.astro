---
const highlights = [
  {
    title: 'Fast Execution',
    desc: '15-minute critical-item turnaround by timing cycles and pre-staging kits.',
  },
  {
    title: 'Zero Breaches',
    desc: 'Maintained a perfect compliance record across all clinic operations.',
  },
  {
    title: 'Team Builder',
    desc: 'Onboarded new hires and authored SOPs to standardize operations.',
  },
  {
    title: 'Clear Communicator',
    desc: 'Trusted liaison to residents and faculty under time pressure.',
  },
];
---

<section id="about" class="py-24 md:py-32 border-t border-border" aria-labelledby="about-heading">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Section label -->
    <div class="reveal mb-14">
      <p class="text-text-muted text-xs font-medium tracking-[0.2em] uppercase mb-4" style="font-family: var(--font-body);">
        01 &mdash; About
      </p>
      <h2 id="about-heading" class="font-heading font-bold text-4xl sm:text-5xl text-primary leading-tight">
        Operations<br><em>is my craft.</em>
      </h2>
    </div>

    <div class="grid lg:grid-cols-5 gap-12 lg:gap-20">

      <!-- Left: narrative -->
      <div class="lg:col-span-2 reveal reveal-delay-1 space-y-5">
        <p class="text-text-secondary text-lg leading-relaxed">
          I'm currently at <span class="font-semibold text-text">Penn Dental Medicine</span> while
          pursuing my B.A.A.S. in Leadership &amp; Communication at the University of Pennsylvania.
        </p>
        <p class="text-text-secondary text-lg leading-relaxed">
          From managing instrument sterilization flows to coordinating multi-clinic logistics,
          I keep complex systems running smoothly under pressure.
        </p>
        <p class="text-text-secondary text-lg leading-relaxed">
          I thrive where precision, communication, and calm problem-solving are essential&mdash;whether
          it's a sub-minute handoff during a procedure or standardizing procedures across an entire market.
        </p>
      </div>

      <!-- Right: highlights — editorial left-border cards -->
      <div class="lg:col-span-3 grid sm:grid-cols-2 gap-6">
        {highlights.map((item, i) => (
          <div class={`reveal reveal-delay-${i + 1} border-l-2 border-accent pl-5 py-1`}>
            <h3 class="font-heading font-semibold text-lg text-text mb-2">{item.title}</h3>
            <p class="text-text-secondary text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
