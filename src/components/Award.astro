---
---

<div class="border-t border-b border-border py-20 md:py-28" aria-label="Recognition">
  <div class="max-w-6xl mx-auto px-6">
    <div class="reveal flex gap-7 items-stretch">

      <!-- Vertical accent rule -->
      <div class="w-[3px] bg-accent-gold shrink-0" aria-hidden="true"></div>

      <div>
        <!-- Label -->
        <p class="flex items-center gap-2.5 text-text-muted text-xs font-medium tracking-[0.2em] uppercase mb-5" style="font-family: var(--font-mono);">
          <svg class="w-2.5 h-2.5 text-accent-gold" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0l2.6 9.4L24 12l-9.4 2.6L12 24l-2.6-9.4L0 12l9.4-2.6z" />
          </svg>
          Recognition
        </p>

        <!-- Award name — large Playfair italic, the eye-stopper -->
        <p class="gilded-text font-heading font-bold italic leading-[0.9]"
           style="font-size: clamp(2.5rem, 6vw, 5rem);">
          Outstanding<br>Service Award
        </p>

        <!-- Attribution -->
        <p class="mt-5 text-text-secondary text-base leading-relaxed" style="font-family: var(--font-body);">
          Penn Dental Medicine, Presented by the Graduating Class
        </p>
      </div>

    </div>
  </div>
</div>
