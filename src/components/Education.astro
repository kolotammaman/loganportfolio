---
---

<section id="education" class="py-24 md:py-32 border-t border-border" aria-labelledby="education-heading">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Section label -->
    <div class="reveal mb-14">
      <p class="text-text-muted text-xs font-medium tracking-[0.2em] uppercase mb-4" style="font-family: var(--font-body);">
        04 / Education
      </p>
      <h2 id="education-heading" class="font-heading font-bold text-4xl sm:text-5xl text-primary leading-tight">
        Ivy League<br><em>foundation.</em>
      </h2>
    </div>

    <div class="reveal reveal-delay-1 space-y-6">
      <div class="glass rounded-xl p-8 sm:p-10 card-hover max-w-2xl">
        <div class="flex flex-col sm:flex-row items-start gap-7">

          <!-- Penn icon — flat accent square -->
          <div class="w-14 h-14 bg-accent flex items-center justify-center shrink-0">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l9-5-9-5-9 5 9 5z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0112 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" />
            </svg>
          </div>

          <div class="flex-1">
            <h3 class="font-heading font-semibold text-xl text-primary">
              University of Pennsylvania
            </h3>
            <p class="text-accent text-sm font-medium mt-1 tracking-wide" style="font-family: var(--font-body);">
              College of Liberal &amp; Professional Studies
            </p>
            <p class="text-text-secondary mt-3 text-lg" style="font-family: var(--font-body);">
              B.A.A.S., Leadership &amp; Communication
            </p>

            <div class="flex flex-wrap gap-3 mt-6">
              <span class="inline-flex items-center gap-2 px-4 py-2 border border-border text-text-secondary text-sm font-medium" style="font-family: var(--font-body);">
                <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                Expected May 2027
              </span>
              <span class="inline-flex items-center gap-2 px-4 py-2 bg-accent text-white text-sm font-semibold" style="font-family: var(--font-body);">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                </svg>
                4.0 GPA
              </span>
            </div>
          </div>

        </div>
      </div>

      <!-- Certifications -->
      <div>
        <p class="text-text-muted text-xs font-medium tracking-[0.2em] uppercase mb-4" style="font-family: var(--font-body);">
          Certifications
        </p>
        <div class="grid sm:grid-cols-2 gap-4 max-w-2xl">

          <div class="glass rounded-xl p-6 border-t-2 border-t-accent card-hover">
            <p class="text-text-muted text-xs font-medium tracking-[0.18em] uppercase mb-2" style="font-family: var(--font-body);">
              CITI Program
            </p>
            <p class="font-heading font-semibold text-primary text-base leading-snug">
              Human Subjects &amp; Biomedical Research
            </p>
          </div>

          <div class="glass rounded-xl p-6 border-t-2 border-t-accent card-hover">
            <p class="text-text-muted text-xs font-medium tracking-[0.18em] uppercase mb-2" style="font-family: var(--font-body);">
              CITI Program
            </p>
            <p class="font-heading font-semibold text-primary text-base leading-snug">
              Good Clinical Practice
            </p>
          </div>

        </div>
      </div>

    </div>

  </div>
</section>
