---
---

<section id="education" class="relative py-24 md:py-32 overflow-hidden" aria-labelledby="education-heading">
  <div class="absolute inset-0 bg-gradient-to-b from-bg via-accent-soft/15 to-bg pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-6xl mx-auto px-6">
    <div class="reveal text-center mb-14">
      <p class="text-accent font-semibold text-sm tracking-widest uppercase mb-3 font-heading">Education</p>
      <h2 id="education-heading" class="font-heading font-black text-3xl sm:text-4xl lg:text-5xl text-text tracking-tight">
        Ivy League foundation.
      </h2>
    </div>

    <div class="reveal reveal-delay-1 max-w-2xl mx-auto">
      <div class="glass rounded-3xl p-8 sm:p-10 card-hover">
        <div class="flex flex-col sm:flex-row items-start gap-6">
          <!-- Penn icon -->
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-accent to-purple-600 flex items-center justify-center shrink-0 shadow-lg shadow-accent/20">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" />
            </svg>
          </div>

          <div class="flex-1">
            <h3 class="font-heading font-bold text-xl text-text">
              University of Pennsylvania
            </h3>
            <p class="text-accent font-semibold mt-1">
              College of Liberal & Professional Studies
            </p>
            <p class="text-text-secondary mt-2 text-lg">
              B.A.A.S., Leadership & Communication
            </p>

            <div class="flex flex-wrap gap-3 mt-6">
              <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-accent/10 text-accent text-sm font-semibold">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                Expected May 2027
              </span>
              <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-amber-500/10 text-amber-600 text-sm font-semibold">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                </svg>
                4.0 GPA
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
