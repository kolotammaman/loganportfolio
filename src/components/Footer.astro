---
const currentYear = new Date().getFullYear();
---

<footer class="py-10 border-t border-border" role="contentinfo">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-3">
        <span class="font-heading font-black text-lg">
          <span class="text-primary">L</span><span class="text-accent">M</span>
        </span>
        <span class="text-border">|</span>
        <p class="text-text-muted text-sm">
          &copy; {currentYear} Logan Moseley
        </p>
      </div>

      <div class="flex items-center gap-4">
        <a
          href="mailto:loganjamesmoseley@gmail.com"
          class="w-10 h-10 rounded-xl bg-primary/5 hover:bg-accent hover:shadow-md hover:shadow-accent/20 flex items-center justify-center text-text-muted hover:text-white transition-all duration-300 cursor-pointer"
          aria-label="Email Logan"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </a>
        <a
          href="tel:+19189246554"
          class="w-10 h-10 rounded-xl bg-primary/5 hover:bg-accent hover:shadow-md hover:shadow-accent/20 flex items-center justify-center text-text-muted hover:text-white transition-all duration-300 cursor-pointer"
          aria-label="Call Logan"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
        </a>
        <a
          href="https://linkedin.com/in/loganjmoseley"
          target="_blank"
          rel="noopener noreferrer"
          class="w-10 h-10 rounded-xl bg-primary/5 hover:bg-accent hover:shadow-md hover:shadow-accent/20 flex items-center justify-center text-text-muted hover:text-white transition-all duration-300 cursor-pointer"
          aria-label="LinkedIn profile"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
