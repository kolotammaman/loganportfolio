---
const jobs = [
  {
    title: 'Instrument Management & Customer Service Specialist',
    company: 'University of Pennsylvania — Penn Dental Medicine',
    location: 'Philadelphia, PA',
    period: 'May 2023 – Present',
    current: true,
    bullets: [
      'Planned/executed daily clinic "program flow"; aligned kit readiness with schedules; maintained zero compliance breaches.',
      'Delivered ~15-minute turnaround on high-need items by timing cycles and pre-staging kits — eliminating chair delays.',
      'Anticipated provider needs (IDs + "usuals") for sub-minute handoffs; de-escalated issues with clear, calm comms.',
      'Produced/maintained materials (signage, checklists, PPT handouts); controlled versions and proofed for clarity.',
      'Coordinated cross-clinic sourcing and vendor equivalents to avoid stockout delays; issued concise status updates.',
      'Onboarded new team members; authored a closing checklist to standardize end-of-day readiness and handoffs.',
    ],
  },
  {
    title: 'Operations Associate',
    company: 'The Rounds',
    location: 'Philadelphia, PA',
    period: 'Sep 2021 – Apr 2023',
    current: false,
    bullets: [
      'Coordinated routes/shifts and field–warehouse comms (Slack/Asana) to improve on-time delivery and service levels.',
      'Resolved customer issues in high-volume settings; documented problems and follow-ups.',
      'Wrote standard operating procedures and optimized job roles across the Philadelphia market.',
      'Trained new hires — promoted from entry-level Packing & Delivery Associate within 3 months.',
    ],
  },
];
---

<section id="experience" class="py-24 md:py-32 border-t border-border" aria-labelledby="experience-heading">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Section label -->
    <div class="reveal mb-14">
      <p class="text-text-muted text-xs font-medium tracking-[0.2em] uppercase mb-4" style="font-family: var(--font-body);">
        02 &mdash; Experience
      </p>
      <h2 id="experience-heading" class="font-heading font-bold text-4xl sm:text-5xl text-primary leading-tight mb-4">
        Where I've<br><em>made impact.</em>
      </h2>
      <p class="text-text-secondary text-lg max-w-xl">
        From logistics startups to Ivy League healthcare, the same relentless focus on execution.
      </p>
    </div>

    <div class="space-y-6">
      {jobs.map((job, jobIndex) => (
        <article class={`reveal reveal-delay-${jobIndex + 1} glass rounded-xl p-7 sm:p-9 card-hover ${job.current ? 'border-l-2 border-l-accent' : ''}`}>

          <!-- Header row -->
          <div class="flex flex-wrap items-start justify-between gap-4 mb-6">
            <div>
              {job.current && (
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-emerald-50 text-emerald-700 text-xs font-semibold tracking-wide uppercase mb-3 border border-emerald-200" style="font-family: var(--font-body);">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse" aria-hidden="true" />
                  Current
                </span>
              )}
              <h3 class="font-heading font-semibold text-xl text-primary">{job.title}</h3>
              <p class="text-accent font-medium mt-1 text-sm tracking-wide" style="font-family: var(--font-body);">{job.company}</p>
            </div>
            <div class="text-right shrink-0">
              <span class="text-text-secondary text-sm font-medium" style="font-family: var(--font-body);">{job.period}</span>
              <p class="text-text-muted text-xs mt-1" style="font-family: var(--font-body);">{job.location}</p>
            </div>
          </div>

          <!-- Bullets -->
          <div class="border-t border-border/60 pt-5">
            <ul class="grid sm:grid-cols-2 gap-x-10 gap-y-3" role="list">
              {job.bullets.map((bullet) => (
                <li class="flex items-start gap-3 text-text-secondary">
                  <span class="w-1 h-1 rounded-full bg-accent/60 shrink-0 mt-2.5" aria-hidden="true" />
                  <span class="text-[15px] leading-relaxed">{bullet}</span>
                </li>
              ))}
            </ul>
          </div>

        </article>
      ))}
    </div>
  </div>
</section>
