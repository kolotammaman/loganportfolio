---
const jobs = [
  {
    title: 'Instrument Management & Customer Service Specialist',
    company: 'University of Pennsylvania — Penn Dental Medicine',
    location: 'Philadelphia, PA',
    period: 'May 2023 – Present',
    current: true,
    bullets: [
      'Planned/executed daily clinic "program flow"; aligned kit readiness with schedules; maintained zero compliance breaches.',
      'Delivered ~15-minute turnaround on high-need items by timing cycles and pre-staging kits — eliminating chair delays.',
      'Anticipated provider needs (IDs + "usuals") for sub-minute handoffs; de-escalated issues with clear, calm comms.',
      'Produced/maintained materials (signage, checklists, PPT handouts); controlled versions and proofed for clarity.',
      'Coordinated cross-clinic sourcing and vendor equivalents to avoid stockout delays; issued concise status updates.',
      'Onboarded new team members; authored a closing checklist to standardize end-of-day readiness and handoffs.',
    ],
  },
  {
    title: 'Operations Associate',
    company: 'The Rounds',
    location: 'Philadelphia, PA',
    period: 'Sep 2021 – Apr 2023',
    current: false,
    bullets: [
      'Coordinated routes/shifts and field–warehouse comms (Slack/Asana) to improve on-time delivery and service levels.',
      'Resolved customer issues in high-volume settings; documented problems and follow-ups.',
      'Wrote standard operating procedures and optimized job roles across the Philadelphia market.',
      'Trained new hires — promoted from entry-level Packing & Delivery Associate within 3 months.',
    ],
  },
];
---

<section id="experience" class="relative py-24 md:py-32 overflow-hidden" aria-labelledby="experience-heading">
  <!-- Subtle background accent -->
  <div class="absolute inset-0 bg-gradient-to-b from-bg via-accent-soft/20 to-bg pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-6xl mx-auto px-6">
    <div class="reveal">
      <p class="text-accent font-semibold text-sm tracking-widest uppercase mb-3 font-heading">Experience</p>
      <h2 id="experience-heading" class="font-heading font-black text-3xl sm:text-4xl lg:text-5xl text-text mb-4 tracking-tight">
        Where I've made impact.
      </h2>
      <p class="text-text-secondary text-lg max-w-2xl">
        From logistics startups to Ivy League healthcare, I bring the same relentless focus on execution.
      </p>
    </div>

    <div class="mt-14 space-y-8">
      {jobs.map((job, jobIndex) => (
        <article class={`reveal reveal-delay-${jobIndex + 1} glass rounded-3xl p-6 sm:p-8 card-hover`}>
          <div class="flex flex-wrap items-start justify-between gap-4 mb-6">
            <div>
              <div class="flex items-center gap-3 mb-2">
                {job.current && (
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full bg-emerald-500/10 text-emerald-600 text-xs font-semibold">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse" aria-hidden="true" />
                    Current
                  </span>
                )}
              </div>
              <h3 class="font-heading font-bold text-xl text-text">
                {job.title}
              </h3>
              <p class="text-accent font-semibold mt-1">
                {job.company}
              </p>
            </div>
            <div class="text-right shrink-0">
              <span class="inline-block px-4 py-1.5 rounded-full bg-primary/5 text-text-secondary text-sm font-medium">
                {job.period}
              </span>
              <p class="text-text-muted text-sm mt-1.5">{job.location}</p>
            </div>
          </div>

          <div class="border-t border-border/50 pt-5">
            <ul class="grid sm:grid-cols-2 gap-x-8 gap-y-3" role="list">
              {job.bullets.map((bullet) => (
                <li class="flex items-start gap-3 text-text-secondary">
                  <svg class="w-4 h-4 text-accent mt-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-[15px] leading-relaxed">{bullet}</span>
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
