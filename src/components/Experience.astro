---
const jobs = [
  {
    title: 'Instrument Management & Customer Service Specialist',
    company: 'University of Pennsylvania, Penn Dental Medicine',
    location: 'Philadelphia, PA',
    period: 'May 2023 to Present',
    current: true,
    bullets: [
      'Coordinate systems and functions across <strong>5 specialty clinics</strong>, serving <strong>200+ dental students</strong>, <strong>30+ residents</strong>, and <strong>30+ faculty</strong> daily. Zero compliance breaches across all clinical operations.',
      'Maintained a <strong>15-minute</strong> turnaround on high-priority items by building a pre-staging system around sterilization cycle timing.',
      'Sterilized, tracked, and accounted for <strong>1,000+ unique dental instruments</strong> across morning and afternoon sessions.',
      'Cross-train new staff regularly across <strong>5 specialty clinics</strong>, each with distinct instrumentation and workflow requirements.',
      'Serve as the first point of contact for residents and faculty under time pressure. I anticipate needs, resolve issues quickly, and keep communication accurate.',
      'Produce and maintain clinic documentation including SOPs, signage, checklists, and training materials managed through version-controlled workflows.',
      'Coordinate cross-clinic sourcing and vendor substitutions to prevent stockouts, with proactive updates to any teams affected.',
      'Authored the closing checklist now used by the full sterilization team to standardize end-of-day readiness.',
    ],
  },
  {
    title: 'Operations Associate',
    company: 'The Rounds',
    location: 'Philadelphia, PA',
    period: 'Sep 2021 to Apr 2023',
    current: false,
    bullets: [
      'Coordinated daily delivery routes and shift logistics across the Philadelphia market using Slack and Asana.',
      'Resolved high-volume customer issues and maintained a running log of problems and resolutions for team reference.',
      'Wrote standard operating procedures that restructured job roles and brought clarity to operations across the market.',
      'Promoted from Packing and Delivery Associate to Operations Associate within three months of starting.',
    ],
  },
  {
    title: 'Young Adult Leadership Committee / Men\'s Group Leader',
    company: 'Saint Agatha-Saint James Catholic Church',
    location: 'Philadelphia, PA',
    period: 'Volunteer, 2023 to Present',
    current: false,
    bullets: [
      'Produced a <strong>sold-out murder mystery event for 100+ paid attendees</strong>: wrote the original script from scratch, designed <strong>9 unique characters</strong>, directed actors, oversaw costume and stage design, managed lighting, secured and paid a live jazz band, and handled all venue logistics. No outside event management support.',
      'Coordinated marketing, ticket sales, and volunteer staffing end-to-end.',
      'Leads a weekly men\'s group: curates discussion topics and manages ongoing programming.',
    ],
  },
];
---

<section id="experience" class="py-24 md:py-32 border-t border-border" aria-labelledby="experience-heading">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Section label -->
    <div class="reveal mb-14">
      <p class="text-text-muted text-xs font-medium tracking-[0.2em] uppercase mb-4" style="font-family: var(--font-body);">
        03 / Experience
      </p>
      <h2 id="experience-heading" class="font-heading font-bold text-3xl sm:text-4xl lg:text-5xl text-primary leading-tight mb-4">
        Where I've<br><em>made impact.</em>
      </h2>
      <p class="text-text-secondary text-lg max-w-xl">
        Two very different environments. The same standard.
      </p>
    </div>

    <div class="space-y-6">
      {jobs.map((job, jobIndex) => (
        <article class={`reveal reveal-delay-${jobIndex + 1} glass rounded-xl p-7 sm:p-9 card-hover ${job.current ? 'border-l-2 border-l-accent-gold' : ''}`}>

          <!-- Header row -->
          <div class="flex flex-wrap items-start justify-between gap-4 mb-6">
            <div>
              {job.current && (
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-emerald-50 text-emerald-700 text-xs font-semibold tracking-wide uppercase mb-3 border border-emerald-200" style="font-family: var(--font-body);">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse" aria-hidden="true" />
                  Current
                </span>
              )}
              <h3 class="font-heading font-semibold text-xl text-primary">{job.title}</h3>
              <p class="text-accent font-medium mt-1 text-sm tracking-wide" style="font-family: var(--font-body);">{job.company}</p>
            </div>
            <div class="text-right shrink-0">
              <span class="text-text-secondary text-sm font-medium" style="font-family: var(--font-body);">{job.period}</span>
              <p class="text-text-muted text-xs mt-1" style="font-family: var(--font-body);">{job.location}</p>
            </div>
          </div>

          <!-- Bullets -->
          <div class="border-t border-border/60 pt-5">
            <ul class="grid sm:grid-cols-2 gap-x-10 gap-y-3" role="list">
              {job.bullets.map((bullet) => (
                <li class="flex items-start gap-3 text-text-secondary">
                  <span class="w-1 h-1 rounded-full bg-accent/60 shrink-0 mt-2.5" aria-hidden="true" />
                  <span class="text-sm leading-relaxed" set:html={bullet}></span>
                </li>
              ))}
            </ul>
          </div>

        </article>
      ))}
    </div>
  </div>
</section>
