---
---

<section id="contact" class="relative py-24 md:py-32 overflow-hidden" aria-labelledby="contact-heading">
  <!-- Background blobs -->
  <div class="blob w-[400px] h-[400px] bg-accent/20 -bottom-20 -right-20" aria-hidden="true"></div>
  <div class="blob w-[300px] h-[300px] bg-purple-400/15 top-10 -left-20" aria-hidden="true"></div>

  <div class="relative max-w-6xl mx-auto px-6">
    <div class="max-w-3xl mx-auto text-center">
      <div class="reveal">
        <p class="text-accent font-semibold text-sm tracking-widest uppercase mb-3 font-heading">Contact</p>
        <h2 id="contact-heading" class="font-heading font-black text-3xl sm:text-4xl lg:text-5xl text-text mb-6 tracking-tight">
          Let's work together.
        </h2>
        <p class="text-text-secondary text-lg leading-relaxed mb-12 max-w-xl mx-auto">
          Interested in project coordination, program operations, or healthcare administration?
          I'd love to hear from you.
        </p>
      </div>

      <div class="reveal reveal-delay-1 grid sm:grid-cols-3 gap-5 max-w-2xl mx-auto">
        <!-- Email -->
        <a
          href="mailto:loganjamesmoseley@gmail.com"
          class="group glass rounded-2xl p-6 card-hover cursor-pointer text-center"
        >
          <div class="w-14 h-14 rounded-2xl bg-accent/10 group-hover:bg-accent group-hover:shadow-lg group-hover:shadow-accent/20 flex items-center justify-center mx-auto mb-4 transition-all duration-300">
            <svg class="w-6 h-6 text-accent group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <p class="font-heading font-bold text-text text-sm mb-1">Email</p>
          <p class="text-text-muted text-xs break-all">loganjamesmoseley<wbr>@gmail.com</p>
        </a>

        <!-- Phone -->
        <a
          href="tel:+19189246554"
          class="group glass rounded-2xl p-6 card-hover cursor-pointer text-center"
        >
          <div class="w-14 h-14 rounded-2xl bg-purple-500/10 group-hover:bg-purple-500 group-hover:shadow-lg group-hover:shadow-purple-500/20 flex items-center justify-center mx-auto mb-4 transition-all duration-300">
            <svg class="w-6 h-6 text-purple-500 group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <p class="font-heading font-bold text-text text-sm mb-1">Phone</p>
          <p class="text-text-muted text-xs">(918) 924-6554</p>
        </a>

        <!-- LinkedIn -->
        <a
          href="https://linkedin.com/in/loganjmoseley"
          target="_blank"
          rel="noopener noreferrer"
          class="group glass rounded-2xl p-6 card-hover cursor-pointer text-center"
        >
          <div class="w-14 h-14 rounded-2xl bg-sky-500/10 group-hover:bg-sky-600 group-hover:shadow-lg group-hover:shadow-sky-600/20 flex items-center justify-center mx-auto mb-4 transition-all duration-300">
            <svg class="w-6 h-6 text-sky-600 group-hover:text-white transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </div>
          <p class="font-heading font-bold text-text text-sm mb-1">LinkedIn</p>
          <p class="text-text-muted text-xs">loganjmoseley</p>
        </a>
      </div>
    </div>
  </div>
</section>
