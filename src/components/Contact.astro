---
---

<section id="contact" class="py-24 md:py-32 border-t border-border" aria-labelledby="contact-heading">
  <div class="max-w-6xl mx-auto px-6">

    <div class="grid lg:grid-cols-2 gap-16 items-start">

      <!-- Left: heading -->
      <div>
        <div class="reveal">
          <p class="text-text-muted text-xs font-medium tracking-[0.2em] uppercase mb-4" style="font-family: var(--font-body);">
            05 &mdash; Contact
          </p>
          <h2 id="contact-heading" class="font-heading font-bold text-4xl sm:text-5xl text-primary leading-tight mb-6">
            Let's work<br><em>together.</em>
          </h2>
          <p class="text-text-secondary text-lg leading-relaxed max-w-sm">
            If you're building something that needs to run well — a team, a program, a workflow — I'd like to be part of it.
          </p>
        </div>
      </div>

      <!-- Right: contact cards -->
      <div class="reveal reveal-delay-1 grid grid-cols-1 sm:grid-cols-2 gap-4">

        <!-- Email -->
        <a
          href="mailto:loganjamesmoseley@gmail.com"
          class="group glass rounded-xl p-7 card-hover cursor-pointer flex flex-col gap-4"
        >
          <div class="w-10 h-10 border border-border flex items-center justify-center group-hover:bg-accent group-hover:border-accent transition-all duration-300">
            <svg class="w-5 h-5 text-accent group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <p class="font-heading font-semibold text-primary text-base mb-1">Email</p>
            <p class="text-text-muted text-xs break-all" style="font-family: var(--font-body);">loganjamesmoseley<wbr>@gmail.com</p>
          </div>
        </a>

        <!-- LinkedIn -->
        <a
          href="https://linkedin.com/in/loganjmoseley"
          target="_blank"
          rel="noopener noreferrer"
          class="group glass rounded-xl p-7 card-hover cursor-pointer flex flex-col gap-4"
        >
          <div class="w-10 h-10 border border-border flex items-center justify-center group-hover:bg-accent group-hover:border-accent transition-all duration-300">
            <svg class="w-5 h-5 text-accent group-hover:text-white transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </div>
          <div>
            <p class="font-heading font-semibold text-primary text-base mb-1">LinkedIn</p>
            <p class="text-text-muted text-xs" style="font-family: var(--font-body);">loganjmoseley</p>
          </div>
        </a>

      </div>
    </div>
  </div>
</section>
