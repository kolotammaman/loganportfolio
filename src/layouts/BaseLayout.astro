---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Logan Moseley" />
    <meta name="theme-color" content="#18181B" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Logan Moseley | Project & Program Operations" />
    <meta property="og:description" content="I coordinate programs, vendors, and cross-functional teams at Penn Dental Medicine. No chaos, no oversight needed. Pursuing B.A.A.S. in Leadership at Penn." />
    <meta property="og:image" content="/og-image.jpg" />
  </head>
  <body class="bg-bg text-text font-body antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-accent focus:text-white focus:px-4 focus:py-2 focus:rounded-lg"
    >
      Skip to main content
    </a>

    <!-- Particle constellation canvas — fixed behind all content -->
    <canvas
      id="particle-canvas"
      aria-hidden="true"
      style="position:fixed;inset:0;width:100%;height:100%;z-index:0;pointer-events:none;"
    ></canvas>

    <div style="position:relative;z-index:1;">
      <slot />
    </div>

    <!-- Particle constellation + organic blob ambient layer -->
    <script>
      (function () {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        const canvas = document.getElementById('particle-canvas') as HTMLCanvasElement;
        const ctx = canvas.getContext('2d')!;

        let W = 0, H = 0;
        function resize() {
          W = canvas.width  = window.innerWidth;
          H = canvas.height = window.innerHeight;
        }
        resize();
        window.addEventListener('resize', resize, { passive: true });

        // ── Color primaries ──
        type RGB = [number, number, number];
        const NEUTRAL: RGB = [17,  17,  16 ];
        const NAVY:    RGB = [28,  53,  87 ];
        const GOLD:    RGB = [196, 149, 58 ];
        const ORANGE:  RGB = [215, 75,  15 ]; // flame / burnt orange
        const RUST:    RGB = [178, 48,  22 ]; // deeper fire

        // Static color types + shift (each shift particle gets its own from/to pair)
        type ColorType = 'neutral' | 'navy' | 'gold' | 'orange' | 'shift';

        // ~half the pool are shifters for more color-changing life
        const COLOR_POOL: ColorType[] = [
          'neutral', 'neutral',
          'navy',
          'gold',
          'orange',
          'shift', 'shift', 'shift', 'shift', 'shift',
        ];

        // Shift pair options — the surprising combinations
        const SHIFT_PAIRS: [RGB, RGB][] = [
          [NAVY,   GOLD  ],
          [NAVY,   GOLD  ],
          [GOLD,   ORANGE],
          [GOLD,   ORANGE],
          [NAVY,   ORANGE],
          [ORANGE, RUST  ],
        ];

        // ── Three depth layers: far / mid / near ──
        const LAYERS = [
          { n: 10, rMin: 0.7, rMax: 1.2, spdMult: 0.55, baseAlpha: 0.13 }, // far
          { n: 12, rMin: 1.3, rMax: 1.9, spdMult: 1.00, baseAlpha: 0.20 }, // mid
          { n:  8, rMin: 2.1, rMax: 3.2, spdMult: 1.55, baseAlpha: 0.28 }, // near
        ];

        interface Particle {
          x: number; y: number;
          baseR: number;                           // frozen radius from layer
          vx: number; vy: number;
          baseAlpha: number;
          breathPhase: number; breathRate: number; breathDepth: number;
          sizePhase: number;   sizeRate: number;   // independent size breathing
          colorType: ColorType;
          colorPhase: number;  colorRate: number;
          shiftFrom: RGB; shiftTo: RGB;            // used only when colorType === 'shift'
        }

        const particles: Particle[] = [];
        for (const L of LAYERS) {
          for (let i = 0; i < L.n; i++) {
            const colorType = COLOR_POOL[Math.floor(Math.random() * COLOR_POOL.length)];
            const pair = SHIFT_PAIRS[Math.floor(Math.random() * SHIFT_PAIRS.length)];
            particles.push({
              x: Math.random() * W,
              y: Math.random() * H,
              baseR: L.rMin + Math.random() * (L.rMax - L.rMin),
              vx: (Math.random() - 0.5) * 0.18 * L.spdMult,
              vy: (Math.random() - 0.5) * 0.18 * L.spdMult,
              baseAlpha:   L.baseAlpha,
              breathPhase: Math.random() * Math.PI * 2,
              breathRate:  0.28 + Math.random() * 0.85,   // opacity breath: 6–22s cycle
              breathDepth: 0.42 + Math.random() * 0.36,
              sizePhase:   Math.random() * Math.PI * 2,
              sizeRate:    0.10 + Math.random() * 0.30,   // size breath: 21–63s cycle — very slow
              colorType,
              colorPhase:  Math.random() * Math.PI * 2,
              colorRate:   0.05 + Math.random() * 0.13,   // color shift: very slow
              shiftFrom: pair[0],
              shiftTo:   pair[1],
            });
          }
        }

        const COUNT = particles.length; // 30

        // ── Organic blobs — 6 blobs, now with visible opacity and flame range ──
        // Previous opacity (~0.02–0.034) was too low to see on cream; bumped to 0.07–0.11
        interface Blob { x:number; y:number; r:number; vx:number; vy:number; rgba:string; }
        const blobs: Blob[] = [
          { x: W*0.10, y: H*0.25, r: 340, vx:  0.020, vy:  0.028, rgba: 'rgba(28,53,87,0.10)'    }, // navy
          { x: W*0.80, y: H*0.52, r: 400, vx: -0.024, vy:  0.018, rgba: 'rgba(18,38,72,0.07)'    }, // deep navy
          { x: W*0.50, y: H*0.76, r: 270, vx:  0.026, vy: -0.022, rgba: 'rgba(196,149,58,0.09)'  }, // gold
          { x: W*0.72, y: H*0.12, r: 310, vx: -0.018, vy:  0.026, rgba: 'rgba(215,75,15,0.09)'   }, // burnt orange
          { x: W*0.28, y: H*0.65, r: 230, vx:  0.030, vy:  0.020, rgba: 'rgba(225,115,25,0.08)'  }, // amber flame
          { x: W*0.88, y: H*0.88, r: 260, vx: -0.022, vy: -0.018, rgba: 'rgba(178,48,22,0.07)'   }, // rust / deep fire
        ];

        const MAX_DIST = 130;

        // ── Helpers ──
        function breathVal(p: Particle, t: number): number {
          return 1 - p.breathDepth + p.breathDepth * (Math.sin(t * p.breathRate + p.breathPhase) * 0.5 + 0.5);
        }

        function currentR(p: Particle, t: number): number {
          // Radius oscillates between 62% and 100% of baseR at its own slow rate
          const env = 0.62 + 0.38 * (Math.sin(t * p.sizeRate + p.sizePhase) * 0.5 + 0.5);
          return p.baseR * env;
        }

        function lerpRGB(a: RGB, b: RGB, mix: number): RGB {
          return [
            Math.round(a[0] + (b[0] - a[0]) * mix),
            Math.round(a[1] + (b[1] - a[1]) * mix),
            Math.round(a[2] + (b[2] - a[2]) * mix),
          ];
        }

        function dotColor(p: Particle, t: number, alpha: number): string {
          let rgb: RGB;
          if      (p.colorType === 'neutral') rgb = NEUTRAL;
          else if (p.colorType === 'navy')    rgb = NAVY;
          else if (p.colorType === 'gold')    rgb = GOLD;
          else if (p.colorType === 'orange')  rgb = ORANGE;
          else {
            // 'shift': blend smoothly between this particle's assigned pair
            const mix = Math.sin(t * p.colorRate + p.colorPhase) * 0.5 + 0.5;
            rgb = lerpRGB(p.shiftFrom, p.shiftTo, mix);
          }
          return `rgba(${rgb[0]},${rgb[1]},${rgb[2]},${alpha.toFixed(3)})`;
        }

        function frame(now: number) {
          const t = now / 1000;
          ctx.clearRect(0, 0, W, H);

          // — Blobs —
          for (const b of blobs) {
            const g = ctx.createRadialGradient(b.x, b.y, 0, b.x, b.y, b.r);
            g.addColorStop(0, b.rgba);
            g.addColorStop(1, 'rgba(0,0,0,0)');
            ctx.beginPath();
            ctx.arc(b.x, b.y, b.r, 0, Math.PI * 2);
            ctx.fillStyle = g;
            ctx.fill();
            b.x += b.vx; b.y += b.vy;
            if (b.x < -b.r)    b.x = W + b.r;
            if (b.x > W + b.r) b.x = -b.r;
            if (b.y < -b.r)    b.y = H + b.r;
            if (b.y > H + b.r) b.y = -b.r;
          }

          // Pre-compute breath and size for each particle
          const breathVals = particles.map(p => breathVal(p, t));

          // — Connections — brightness tracks the average breath of both endpoints
          for (let i = 0; i < COUNT; i++) {
            for (let j = i + 1; j < COUNT; j++) {
              const dx = particles[i].x - particles[j].x;
              const dy = particles[i].y - particles[j].y;
              const d  = Math.sqrt(dx * dx + dy * dy);
              if (d < MAX_DIST) {
                const avgBreath = (breathVals[i] + breathVals[j]) * 0.5;
                const avgAlpha  = (particles[i].baseAlpha + particles[j].baseAlpha) * 0.5;
                const lineAlpha = avgAlpha * avgBreath * (1 - d / MAX_DIST) * 0.55;
                ctx.beginPath();
                ctx.moveTo(particles[i].x, particles[i].y);
                ctx.lineTo(particles[j].x, particles[j].y);
                ctx.strokeStyle = `rgba(17,17,16,${lineAlpha.toFixed(3)})`;
                ctx.lineWidth = 0.5;
                ctx.stroke();
              }
            }
          }

          // — Dots —
          for (let i = 0; i < COUNT; i++) {
            const p = particles[i];
            const alpha = p.baseAlpha * breathVals[i];
            const r     = currentR(p, t);
            ctx.beginPath();
            ctx.arc(p.x, p.y, r, 0, Math.PI * 2);
            ctx.fillStyle = dotColor(p, t, alpha);
            ctx.fill();

            p.x += p.vx; p.y += p.vy;
            if (p.x < -4)    p.x = W + 4;
            if (p.x > W + 4) p.x = -4;
            if (p.y < -4)    p.y = H + 4;
            if (p.y > H + 4) p.y = -4;
          }

          requestAnimationFrame(frame);
        }

        requestAnimationFrame(frame);
      })();
    </script>

    <!-- Scroll reveal observer -->
    <script>
      // requestAnimationFrame defers class addition to the start of the next
      // render frame. Without it, classList.add fires mid-scroll-callback which
      // can land mid-frame on mobile, causing a visible stutter as the browser
      // recalculates styles during an already-busy scroll frame.
      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries.filter((e) => e.isIntersecting);
          if (!visible.length) return;
          requestAnimationFrame(() => {
            visible.forEach((entry) => {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            });
          });
        },
        { threshold: 0.06, rootMargin: '0px 0px -20px 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
