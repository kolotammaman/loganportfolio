---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Logan Moseley" />
    <meta name="theme-color" content="#18181B" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Logan Moseley | Project & Program Operations" />
    <meta property="og:description" content="I coordinate programs, vendors, and cross-functional teams at Penn Dental Medicine. No chaos, no oversight needed. Pursuing B.A.A.S. in Leadership at Penn." />
    <meta property="og:image" content="/og-image.jpg" />
  </head>
  <body class="bg-bg text-text font-body antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-accent focus:text-white focus:px-4 focus:py-2 focus:rounded-lg"
    >
      Skip to main content
    </a>

    <!-- Particle constellation canvas — fixed behind all content -->
    <canvas
      id="particle-canvas"
      aria-hidden="true"
      style="position:fixed;inset:0;width:100%;height:100%;z-index:0;pointer-events:none;"
    ></canvas>

    <div style="position:relative;z-index:1;">
      <slot />
    </div>

    <!-- Particle constellation + organic blob ambient layer -->
    <script>
      (function () {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        const canvas = document.getElementById('particle-canvas') as HTMLCanvasElement;
        const ctx = canvas.getContext('2d')!;

        let W = 0, H = 0;
        function resize() {
          W = canvas.width  = window.innerWidth;
          H = canvas.height = window.innerHeight;
        }
        resize();
        window.addEventListener('resize', resize, { passive: true });

        // ── Color primaries ──
        type RGB = [number, number, number];
        const NEUTRAL: RGB = [17,  17,  16];
        const NAVY:    RGB = [28,  53,  87];
        const GOLD:    RGB = [196, 149, 58];
        const ORANGE:  RGB = [215, 75,  15];
        const RUST:    RGB = [178, 48,  22];

        type ColorType = 'neutral' | 'navy' | 'gold' | 'orange' | 'shift';
        const COLOR_POOL: ColorType[] = [
          'neutral', 'neutral', 'navy', 'gold', 'orange',
          'shift', 'shift', 'shift', 'shift', 'shift',
        ];
        const SHIFT_PAIRS: [RGB, RGB][] = [
          [NAVY, GOLD], [NAVY, GOLD],
          [GOLD, ORANGE], [GOLD, ORANGE],
          [NAVY, ORANGE],
          [ORANGE, RUST],
        ];

        // ── Depth layers — feature layer bumped to 13px max ──
        const LAYERS = [
          { n: 10, rMin: 0.7, rMax:  1.2, spdMult: 0.55, baseAlpha: 0.13 }, // far
          { n: 12, rMin: 1.3, rMax:  2.4, spdMult: 1.00, baseAlpha: 0.22 }, // mid
          { n:  5, rMin: 3.0, rMax:  5.5, spdMult: 1.55, baseAlpha: 0.32 }, // near
          { n:  3, rMin: 7.0, rMax: 13.0, spdMult: 1.20, baseAlpha: 0.40 }, // feature
        ];

        interface TrailPos { x: number; y: number; }
        type TrailState = 'idle' | 'fadein' | 'active' | 'fadeout';

        interface Particle {
          x: number; y: number; baseR: number;
          vx: number; vy: number; baseAlpha: number;
          breathPhase: number; breathRate: number; breathDepth: number;
          sizePhase:   number; sizeRate:   number;
          colorType: ColorType; colorPhase: number; colorRate: number;
          shiftFrom: RGB; shiftTo: RGB;
          // Trail
          trail: TrailPos[]; trailAlpha: number; trailState: TrailState;
          trailFadeStart: number; trailActiveUntil: number;
          // Speed boost
          boostStartTime: number; boostDuration: number;
        }

        const particles: Particle[] = [];
        for (const L of LAYERS) {
          for (let i = 0; i < L.n; i++) {
            const colorType = COLOR_POOL[Math.floor(Math.random() * COLOR_POOL.length)];
            const pair = SHIFT_PAIRS[Math.floor(Math.random() * SHIFT_PAIRS.length)];
            particles.push({
              x: Math.random() * W, y: Math.random() * H,
              baseR: L.rMin + Math.random() * (L.rMax - L.rMin),
              vx: (Math.random() - 0.5) * 0.18 * L.spdMult,
              vy: (Math.random() - 0.5) * 0.18 * L.spdMult,
              baseAlpha:   L.baseAlpha,
              breathPhase: Math.random() * Math.PI * 2,
              breathRate:  0.28 + Math.random() * 0.85,
              breathDepth: 0.42 + Math.random() * 0.36,
              sizePhase:   Math.random() * Math.PI * 2,
              sizeRate:    0.10 + Math.random() * 0.30,
              colorType,
              colorPhase:  Math.random() * Math.PI * 2,
              colorRate:   0.05 + Math.random() * 0.13,
              shiftFrom: pair[0], shiftTo: pair[1],
              trail: [], trailAlpha: 0, trailState: 'idle',
              trailFadeStart: 0, trailActiveUntil: 0,
              boostStartTime: 15 + Math.random() * 50,
              boostDuration:  5  + Math.random() * 7,
            });
          }
        }
        const COUNT = particles.length;

        // ── Blobs ──
        interface Blob { x:number; y:number; r:number; vx:number; vy:number; rgba:string; }
        const blobs: Blob[] = [
          { x: W*0.10, y: H*0.25, r: 340, vx:  0.020, vy:  0.028, rgba: 'rgba(28,53,87,0.10)'   },
          { x: W*0.80, y: H*0.52, r: 400, vx: -0.024, vy:  0.018, rgba: 'rgba(18,38,72,0.07)'   },
          { x: W*0.50, y: H*0.76, r: 270, vx:  0.026, vy: -0.022, rgba: 'rgba(196,149,58,0.09)' },
          { x: W*0.72, y: H*0.12, r: 310, vx: -0.018, vy:  0.026, rgba: 'rgba(215,75,15,0.09)'  },
          { x: W*0.28, y: H*0.65, r: 230, vx:  0.030, vy:  0.020, rgba: 'rgba(225,115,25,0.08)' },
          { x: W*0.88, y: H*0.88, r: 260, vx: -0.022, vy: -0.018, rgba: 'rgba(178,48,22,0.07)'  },
        ];

        const MAX_DIST = 130;

        // ── Helpers ──
        function breathVal(p: Particle, t: number): number {
          return 1 - p.breathDepth + p.breathDepth * (Math.sin(t * p.breathRate + p.breathPhase) * 0.5 + 0.5);
        }
        function currentR(p: Particle, t: number): number {
          return p.baseR * (0.62 + 0.38 * (Math.sin(t * p.sizeRate + p.sizePhase) * 0.5 + 0.5));
        }
        function lerpRGB(a: RGB, b: RGB, mix: number): RGB {
          return [
            Math.round(a[0] + (b[0] - a[0]) * mix),
            Math.round(a[1] + (b[1] - a[1]) * mix),
            Math.round(a[2] + (b[2] - a[2]) * mix),
          ];
        }
        function dotColor(p: Particle, t: number, alpha: number): string {
          let rgb: RGB;
          if      (p.colorType === 'neutral') rgb = NEUTRAL;
          else if (p.colorType === 'navy')    rgb = NAVY;
          else if (p.colorType === 'gold')    rgb = GOLD;
          else if (p.colorType === 'orange')  rgb = ORANGE;
          else {
            const mix = Math.sin(t * p.colorRate + p.colorPhase) * 0.5 + 0.5;
            rgb = lerpRGB(p.shiftFrom, p.shiftTo, mix);
          }
          return `rgba(${rgb[0]},${rgb[1]},${rgb[2]},${alpha.toFixed(3)})`;
        }
        // Speed boost: smooth bell-curve pulse, barely perceptible (+35% peak)
        function speedBoost(p: Particle, t: number): number {
          if (t < p.boostStartTime) return 1;
          const elapsed = t - p.boostStartTime;
          if (elapsed > p.boostDuration) {
            p.boostStartTime = t + 30 + Math.random() * 60;
            p.boostDuration  = 5  + Math.random() * 7;
            return 1;
          }
          return 1 + 0.35 * Math.sin(Math.PI * elapsed / p.boostDuration);
        }

        let frameCount = 0;
        let nextTrailCheck = 3; // first scheduling attempt at t=3s

        function frame(now: number) {
          const t = now / 1000;
          frameCount++;

          ctx.clearRect(0, 0, W, H);

          // — Blobs —
          for (const b of blobs) {
            const g = ctx.createRadialGradient(b.x, b.y, 0, b.x, b.y, b.r);
            g.addColorStop(0, b.rgba);
            g.addColorStop(1, 'rgba(0,0,0,0)');
            ctx.beginPath();
            ctx.arc(b.x, b.y, b.r, 0, Math.PI * 2);
            ctx.fillStyle = g;
            ctx.fill();
            b.x += b.vx; b.y += b.vy;
            if (b.x < -b.r)    b.x = W + b.r;
            if (b.x > W + b.r) b.x = -b.r;
            if (b.y < -b.r)    b.y = H + b.r;
            if (b.y > H + b.r) b.y = -b.r;
          }

          // — Trail scheduling: 1–3 trails active at a time —
          if (t > nextTrailCheck) {
            nextTrailCheck = t + 2 + Math.random() * 4;
            const active = particles.filter(p => p.trailState !== 'idle').length;
            if (active < 3 && Math.random() < 0.75) {
              const numNew = Math.random() < 0.35 ? 2 : 1;
              const idle = particles.filter(p => p.trailState === 'idle');
              for (let k = idle.length - 1; k > 0; k--) {
                const j = Math.floor(Math.random() * (k + 1));
                [idle[k], idle[j]] = [idle[j], idle[k]];
              }
              for (let k = 0; k < Math.min(numNew, idle.length); k++) {
                idle[k].trailState      = 'fadein';
                idle[k].trailFadeStart  = t;
                idle[k].trailActiveUntil = t + 4 + Math.random() * 9;
                idle[k].trail           = [];
                idle[k].trailAlpha      = 0;
              }
            }
          }

          // — Trail state machine —
          for (const p of particles) {
            if (p.trailState === 'fadein') {
              p.trailAlpha = Math.min(1, (t - p.trailFadeStart) / 1.8);
              if (p.trailAlpha >= 1) p.trailState = 'active';
            } else if (p.trailState === 'active') {
              p.trailAlpha = 1;
              if (t >= p.trailActiveUntil) { p.trailState = 'fadeout'; p.trailFadeStart = t; }
            } else if (p.trailState === 'fadeout') {
              p.trailAlpha = Math.max(0, 1 - (t - p.trailFadeStart) / 2.5);
              if (p.trailAlpha <= 0) { p.trailState = 'idle'; p.trail = []; }
            }
          }

          // — Record trail positions every 3 frames —
          if (frameCount % 3 === 0) {
            for (const p of particles) {
              if (p.trailState !== 'idle') {
                p.trail.push({ x: p.x, y: p.y });
                if (p.trail.length > 28) p.trail.shift();
              }
            }
          }

          const breathVals = particles.map(p => breathVal(p, t));

          // — Connections —
          for (let i = 0; i < COUNT; i++) {
            for (let j = i + 1; j < COUNT; j++) {
              const dx = particles[i].x - particles[j].x;
              const dy = particles[i].y - particles[j].y;
              const d  = Math.sqrt(dx * dx + dy * dy);
              if (d < MAX_DIST) {
                const avgBreath = (breathVals[i] + breathVals[j]) * 0.5;
                const avgAlpha  = (particles[i].baseAlpha + particles[j].baseAlpha) * 0.5;
                const lineAlpha = avgAlpha * avgBreath * (1 - d / MAX_DIST) * 0.55;
                ctx.beginPath();
                ctx.moveTo(particles[i].x, particles[i].y);
                ctx.lineTo(particles[j].x, particles[j].y);
                ctx.strokeStyle = `rgba(17,17,16,${lineAlpha.toFixed(3)})`;
                ctx.lineWidth = 0.5;
                ctx.stroke();
              }
            }
          }

          // — Draw trails —
          for (let i = 0; i < COUNT; i++) {
            const p = particles[i];
            if (p.trailAlpha < 0.01 || p.trail.length < 2) continue;
            const len = p.trail.length;
            const r0  = currentR(p, t);
            for (let k = 0; k < len; k++) {
              const prog = k / (len - 1);
              const tA   = p.trailAlpha * prog * prog * p.baseAlpha * breathVals[i] * 0.9;
              const tR   = Math.max(0.3, r0 * prog * 0.65);
              if (tA > 0.004) {
                ctx.beginPath();
                ctx.arc(p.trail[k].x, p.trail[k].y, tR, 0, Math.PI * 2);
                ctx.fillStyle = dotColor(p, t, tA);
                ctx.fill();
              }
            }
          }

          // — Draw dots —
          for (let i = 0; i < COUNT; i++) {
            const p = particles[i];
            ctx.beginPath();
            ctx.arc(p.x, p.y, currentR(p, t), 0, Math.PI * 2);
            ctx.fillStyle = dotColor(p, t, p.baseAlpha * breathVals[i]);
            ctx.fill();
          }

          // — Move particles —
          for (const p of particles) {
            const boost = speedBoost(p, t);
            p.x += p.vx * boost; p.y += p.vy * boost;
            if (p.x < -14)    p.x = W + 14;
            if (p.x > W + 14) p.x = -14;
            if (p.y < -14)    p.y = H + 14;
            if (p.y > H + 14) p.y = -14;
          }

          requestAnimationFrame(frame);
        }

        requestAnimationFrame(frame);
      })();
    </script>

    <!-- Scroll reveal observer -->
    <script>
      // requestAnimationFrame defers class addition to the start of the next
      // render frame. Without it, classList.add fires mid-scroll-callback which
      // can land mid-frame on mobile, causing a visible stutter as the browser
      // recalculates styles during an already-busy scroll frame.
      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries.filter((e) => e.isIntersecting);
          if (!visible.length) return;
          requestAnimationFrame(() => {
            visible.forEach((entry) => {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            });
          });
        },
        { threshold: 0.06, rootMargin: '0px 0px -20px 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
